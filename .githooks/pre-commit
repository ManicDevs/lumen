#!/bin/bash
# =============================================================================
# Lumen — Git pre-commit hook
# Installs: make hooks-install
# =============================================================================
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

pass() { echo -e "${GREEN}✓${NC} $1"; }
fail() { echo -e "${RED}✗${NC} $1"; exit 1; }
warn() { echo -e "${YELLOW}⚠${NC} $1"; }

echo "Running pre-commit checks..."
echo ""

# ── Check 1: gofmt ────────────────────────────────────────────────────────────
DIFF=$(gofmt -s -d . 2>/dev/null)
if [ -n "$DIFF" ]; then
    echo "$DIFF"
    fail "gofmt found unformatted files. Run: make fmt"
fi
pass "gofmt"

# ── Check 2: go vet ───────────────────────────────────────────────────────────
if ! go vet ./... 2>/dev/null; then
    fail "go vet found issues"
fi
pass "go vet"

# ── Check 3: golangci-lint (if installed) ─────────────────────────────────────
if command -v golangci-lint &>/dev/null; then
    if ! golangci-lint run --timeout=3m ./... 2>/dev/null; then
        fail "golangci-lint found issues"
    fi
    pass "golangci-lint"
else
    warn "golangci-lint not installed, skipping"
fi

# ── Check 4: No secrets in staged files ──────────────────────────────────────
STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if echo "$STAGED" | grep -qiE '\.(pem|key|env)$'; then
    fail "Staged file looks like a secret. Use .env.example for templates."
fi
if git diff --cached --diff-filter=ACM 2>/dev/null | grep -qiE '(api_key|secret_key|password)\s*[:=]\s*["\x27]?[A-Za-z0-9]{16,}'; then
    fail "Possible secret detected in staged changes."
fi
pass "No secrets detected"

# ── Check 5: go.mod tidiness ─────────────────────────────────────────────────
go mod tidy 2>/dev/null 1>/dev/null || true
DIFF=$(git diff go.mod go.sum 2>/dev/null || true)
if [ -n "$DIFF" ]; then
    echo "$DIFF"
    warn "go.mod/go.sum changed after tidy — stage the changes and re-commit"
    exit 1
fi
pass "go.mod tidy"

# ── Check 6: Test compilation ────────────────────────────────────────────────
if ! go build ./... 2>/dev/null; then
    fail "Build failed"
fi
pass "Build"

echo ""
echo -e "${GREEN}All pre-commit checks passed.${NC}"
