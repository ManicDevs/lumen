#!/bin/bash
# =============================================================================
# Lumen — Git commit-msg hook
# Validates conventional commit format:
#   type(scope): description
#   type: description
# Installs: make hooks-install
# =============================================================================
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

MSG_FILE="$1"
MSG=$(head -1 "$MSG_FILE")

# Allowed types
TYPES="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|deps"

# Match conventional commit format
if ! echo "$MSG" | grep -qE "^(${TYPES})(\(.+\))?: .{1,}"; then
    echo ""
    echo -e "${RED}✗ Invalid commit message format${NC}"
    echo ""
    echo "  Got:      $MSG"
    echo ""
    echo "  Expected: type(scope): description"
    echo ""
    echo "  Types:    feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert, deps"
    echo ""
    echo "  Examples:"
    echo "    feat: add streaming support"
    echo "    fix(ollama): handle empty response"
    echo "    docs: update README"
    echo "    deps: update golangci-lint"
    echo ""
    exit 1
fi

# Check max length (first line <= 72 chars)
if [ ${#MSG} -gt 72 ]; then
    echo ""
    echo -e "${YELLOW}⚠ Commit subject line is ${#MSG} chars (max 72)${NC}"
    echo "  $MSG"
    echo ""
fi

exit 0
