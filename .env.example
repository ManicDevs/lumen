# Lumen — LLM Code Diagnostic Engine
# Copy this file to .env to override any of the defaults below.
# Real shell `export` values always take priority over this file.
#
# Lumen runs entirely on a local Ollama server — no cloud provider, no API
# keys, no per-token billing. Point OLLAMA_HOST at any reachable Ollama
# instance (defaults to localhost).

# ==============================================================================
# Ollama (native /api/chat)
# ==============================================================================

# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder:3b
# OLLAMA_NUM_CTX=8192

# ==============================================================================
# Runtime
# ==============================================================================

# LOG_FORMAT=text         # text or json
# LOG_LEVEL=info          # debug, info, warn, error
# REQUEST_TIMEOUT_SECONDS=60
# MAX_RETRIES=4
# SESSION_DIR=~/.lumen/sessions
